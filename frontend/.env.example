# Copy to .env.local for local overrides.
# Production (Render): https://github.com/pushkar462/Contextra — UI https://contextra-1.onrender.com · API https://contextra-b.onrender.com
# Backend URL (no trailing slash). Leave unset in dev to use the Vite proxy to localhost:8000.
VITE_API_BASE_URL=https://contextra-b.onrender.com
# Optional: if the API requires X-API-Key (must match backend API_KEY)
# VITE_API_KEY=
